# Public release repository .gitignore.
#
# This file is OWNED by the release repo and preserved across promotions -- it is
# never overwritten by tools/promote. Keep it free of any reference to private,
# dev-only paths (those must never leave a trace in the public tree).

# Python virtual environment
.venv/
venv/

# Python bytecode cache
__pycache__/
*.py[cod]
*$py.class

# Build / distribution artifacts (release binaries ship as separate release assets,
# not committed to the repo)
build/
dist/

# IDE / editor
.idea/
.vscode/

# OS junk
.DS_Store
Thumbs.db
